# OpenAI-compatible LLM settings
LLM_API_KEY=your-api-key
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1
LLM_TIMEOUT=60
# Disable this when the configured LLM cannot inspect images.
ECHOBOT_LLM_SUPPORTS_IMAGE_INPUT=true
# Optional: extra fields merged into every request body (JSON object)
# Example: LLM_EXTRA_BODY={"chat_template_kwargs": {"enable_thinking": false}}
LLM_EXTRA_BODY=

# Lightweight orchestration max_tokens budget
# Used by the decision layer and short roleplay replies
ECHOBOT_LIGHTWEIGHT_MAX_TOKENS=4096

# Single-turn agent tool/skill loop step limit
ECHOBOT_AGENT_MAX_STEPS=50

# Image upload budget
# Applies to Web uploads and channel image ingestion.
ECHOBOT_IMAGE_MAX_INPUT_BYTES=41943040
ECHOBOT_IMAGE_MAX_OUTPUT_BYTES=4194304
ECHOBOT_IMAGE_MAX_SIDE=3072
ECHOBOT_IMAGE_MAX_PIXELS=24000000

# File upload budget
# Applies to Web uploads and channel file ingestion.
ECHOBOT_FILE_MAX_INPUT_BYTES=209715200

# Whether to send a short "I'm checking" acknowledgement before delegating
# to the full background agent
ECHOBOT_DELEGATED_ACK_ENABLED=true

# Trusted user header mode
# Enable when EchoBot is behind Cloudflare Access or a trusted reverse proxy.
# When enabled and required, /web, /api/*, and /api/web/asr/ws reject requests
# that do not include a valid trusted user header.
ECHOBOT_TRUSTED_USER_HEADER_ENABLED=false
ECHOBOT_TRUSTED_USER_REQUIRED=false
ECHOBOT_TRUSTED_USER_HEADER=Cf-Access-Authenticated-User-Email

# Admin mutation guard
# When set, mutating admin APIs require the trusted user id to be listed here.
# Leave empty for local single-user development.
ECHOBOT_ADMIN_ALLOWLIST=
ECHOBOT_ADMIN_REQUIRED=false

# Open WebUI operator bridge
# Set a strong random token before importing /api/openwebui/tools/openapi.json
# into Open WebUI. The admin page only shows whether the token is configured.
ECHOBOT_OPENWEBUI_BRIDGE_TOKEN=
# Optional default target user for server-to-server bridge calls.
ECHOBOT_OPENWEBUI_BRIDGE_USER_ID=
# Open WebUI bridge calls must target a trusted-user namespace by default.
ECHOBOT_OPENWEBUI_REQUIRE_TARGET_USER=true
# Optional comma-separated allowlist for Open WebUI target_user_id values.
ECHOBOT_OPENWEBUI_ALLOWED_TARGET_USERS=
# Keep disabled unless you intentionally want Open WebUI to request agent routing.
ECHOBOT_OPENWEBUI_OPERATOR_AGENT_ENABLED=false

# Shell command safety mode
# Available values: danger-full-access, workspace-write, read-only
# Public-safe default. Use danger-full-access only on a trusted private host
# after reviewing the Agent tool permissions.
ECHOBOT_SHELL_SAFETY_MODE=workspace-write

# Runtime logging
REME_LOG_LEVEL=WARNING
AGENTSCOPE_LOG_LEVEL=WARNING

# Web Live2D
ECHOBOT_WEB_LIVE2D_MODEL=

# Web TTS
ECHOBOT_TTS_PROVIDER=edge
ECHOBOT_TTS_KOKORO_AUTO_DOWNLOAD=true
ECHOBOT_TTS_KOKORO_MODEL_DIR=
ECHOBOT_TTS_KOKORO_PROVIDER=cpu
ECHOBOT_TTS_KOKORO_NUM_THREADS=2
ECHOBOT_TTS_KOKORO_DEFAULT_VOICE=zf_001
ECHOBOT_TTS_KOKORO_DOWNLOAD_TIMEOUT_SECONDS=600
ECHOBOT_TTS_KOKORO_URL=
ECHOBOT_TTS_KOKORO_LENGTH_SCALE=1.0
ECHOBOT_TTS_KOKORO_LANG=

# TTS provider: openai-compatible
# Works with OpenAI-compatible /audio/speech endpoints,
# including OpenAI, vLLM, and local servers that expose the same API.
ECHOBOT_TTS_OPENAI_API_KEY=EMPTY
ECHOBOT_TTS_OPENAI_MODEL=
ECHOBOT_TTS_OPENAI_BASE_URL=https://api.openai.com/v1
ECHOBOT_TTS_OPENAI_TIMEOUT=60
ECHOBOT_TTS_OPENAI_DEFAULT_VOICE=alloy
ECHOBOT_TTS_OPENAI_RESPONSE_FORMAT=wav
# Optional: fallback voices for servers that do not expose GET /v1/audio/voices
ECHOBOT_TTS_OPENAI_VOICES=
ECHOBOT_TTS_OPENAI_INSTRUCTIONS=
# Optional: extra fields passed through audio.speech.create(..., extra_body=...)
# Example: ECHOBOT_TTS_OPENAI_EXTRA_BODY={"language":"English","task_type":"CustomVoice"}
ECHOBOT_TTS_OPENAI_EXTRA_BODY=

# Web ASR
ECHOBOT_ASR_PROVIDER=sherpa-sense-voice
ECHOBOT_ASR_SAMPLE_RATE=16000

# ASR provider: sherpa-sense-voice
ECHOBOT_ASR_SHERPA_AUTO_DOWNLOAD=true
ECHOBOT_ASR_SHERPA_MODEL_DIR=
ECHOBOT_ASR_SHERPA_EXECUTION_PROVIDER=cpu
ECHOBOT_ASR_SHERPA_NUM_THREADS=2
ECHOBOT_ASR_SHERPA_LANGUAGE=auto
ECHOBOT_ASR_SHERPA_USE_ITN=false
ECHOBOT_ASR_SHERPA_DOWNLOAD_TIMEOUT_SECONDS=600
ECHOBOT_ASR_SHERPA_MODEL_URL=

# ASR provider: openai-transcriptions
# Works with OpenAI-compatible /audio/transcriptions endpoints,
# including OpenAI, vLLM, and local servers that expose the same API.
ECHOBOT_ASR_OPENAI_API_KEY=EMPTY
ECHOBOT_ASR_OPENAI_MODEL=
ECHOBOT_ASR_OPENAI_BASE_URL=https://api.openai.com/v1
ECHOBOT_ASR_OPENAI_TIMEOUT=60
ECHOBOT_ASR_OPENAI_LANGUAGE=
ECHOBOT_ASR_OPENAI_PROMPT=
ECHOBOT_ASR_OPENAI_TEMPERATURE=

# Web VAD
# Leave empty or set to none to disable always-listen.
ECHOBOT_VAD_PROVIDER=silero

# VAD provider: silero
ECHOBOT_VAD_SILERO_AUTO_DOWNLOAD=true
ECHOBOT_VAD_SILERO_MODEL_DIR=
ECHOBOT_VAD_SILERO_EXECUTION_PROVIDER=cpu
ECHOBOT_VAD_SILERO_DOWNLOAD_TIMEOUT_SECONDS=600
ECHOBOT_VAD_SILERO_MODEL_URL=
ECHOBOT_VAD_SILERO_THRESHOLD=0.5
ECHOBOT_VAD_SILERO_MIN_SILENCE_SECONDS=0.4
ECHOBOT_VAD_SILERO_MIN_SPEECH_SECONDS=0.2
ECHOBOT_VAD_SILERO_MAX_SPEECH_SECONDS=30
ECHOBOT_VAD_SILERO_WINDOW_SIZE=512
