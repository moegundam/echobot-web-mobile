# EchoBot Local Tunnel profile

# OpenAI-compatible LLM settings
# Use an external OpenAI-compatible API by default. For Ollama or vLLM,
# change LLM_BASE_URL and LLM_MODEL.
LLM_API_KEY=your-api-key
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1
LLM_TIMEOUT=60
ECHOBOT_LLM_SUPPORTS_IMAGE_INPUT=true
LLM_EXTRA_BODY=

# Runtime safety for 10-person testing
# Keep Agent permissions scoped for private testing.
ECHOBOT_DEPLOYMENT_PROFILE=tunnel
ECHOBOT_SHELL_SAFETY_MODE=workspace-write
ECHOBOT_WEB_PRIVATE_NETWORK_ENABLED=false
ECHOBOT_DELEGATED_ACK_ENABLED=true
ECHOBOT_AGENT_MAX_STEPS=50
ECHOBOT_LIGHTWEIGHT_MAX_TOKENS=4096

# Keep user runtimes bounded during a small private test.
ECHOBOT_USER_RUNTIME_MAX_ENTRIES=16
ECHOBOT_USER_RUNTIME_IDLE_TTL_SECONDS=1800

# Local Tunnel runs one EchoBot worker by default. Use Redis before increasing
# the worker count or Stage events will be split between processes.
ECHOBOT_STAGE_BROKER=memory
ECHOBOT_STAGE_WORKER_COUNT=1
ECHOBOT_STAGE_REDIS_URL=
ECHOBOT_STAGE_HISTORY_LIMIT=100
ECHOBOT_STAGE_QUEUE_LIMIT=100
ECHOBOT_STAGE_MAX_CHANNELS=256
ECHOBOT_STAGE_HEARTBEAT_SECONDS=15
ECHOBOT_STAGE_REDIS_TTL_SECONDS=86400
ECHOBOT_STAGE_REDIS_READ_BLOCK_MS=1000
ECHOBOT_STAGE_REDIS_STREAM_KEY_PREFIX=echobot:stage-events

# Cloudflare Access trusted user header
# This header must be injected by Cloudflare Access or a trusted reverse proxy.
ECHOBOT_TRUSTED_USER_HEADER_ENABLED=true
ECHOBOT_TRUSTED_USER_REQUIRED=true
ECHOBOT_TRUSTED_USER_ASSERTION_REQUIRED=true
ECHOBOT_TRUSTED_USER_HEADER=Cf-Access-Authenticated-User-Email

# Admin mutation guard
# Put owner/admin emails allowed to change secrets and persistent settings here.
ECHOBOT_ADMIN_ALLOWLIST=admin@example.com
ECHOBOT_ADMIN_REQUIRED=true

# Optional Console operators. They can operate sessions and Stage without
# receiving access to Admin pages, secrets, provider endpoints, or Agent tools.
ECHOBOT_OPERATOR_ALLOWLIST=operator@example.com

# Open WebUI operator bridge
# Configure exactly one of TOKEN or TOKEN_FILE and use the same bearer value in
# Open WebUI. TOKEN_FILE is preferred for mounted secrets. Never commit it.
# ECHOBOT_OPENWEBUI_BRIDGE_TOKEN=<strong-random-value>
# ECHOBOT_OPENWEBUI_BRIDGE_TOKEN_FILE=/run/secrets/echobot-openwebui-token
# Optional: set this when Open WebUI should always target one Cloudflare
# Access user namespace unless a tool call supplies target_user_id.
ECHOBOT_OPENWEBUI_BRIDGE_USER_ID=
# Keep true so Open WebUI never writes into the shared root runtime by accident.
ECHOBOT_OPENWEBUI_REQUIRE_TARGET_USER=true
# Required comma-separated allowlist for Open WebUI target_user_id values.
# Leave empty to deny all target_user_id values.
ECHOBOT_OPENWEBUI_ALLOWED_TARGET_USERS=
# Keep false by default. chat_only remains the safe bridge mode.
ECHOBOT_OPENWEBUI_OPERATOR_AGENT_ENABLED=false

# Upload budgets
# Conservative defaults for 10-person testing.
ECHOBOT_IMAGE_MAX_INPUT_BYTES=41943040
ECHOBOT_IMAGE_MAX_OUTPUT_BYTES=4194304
ECHOBOT_IMAGE_MAX_SIDE=3072
ECHOBOT_IMAGE_MAX_PIXELS=24000000
ECHOBOT_FILE_MAX_INPUT_BYTES=26214400

# Web Live2D
ECHOBOT_WEB_LIVE2D_MODEL=

# Web TTS
# edge is the lightest local-tunnel default. Use kokoro only on stronger hosts.
ECHOBOT_TTS_PROVIDER=edge
ECHOBOT_TTS_KOKORO_AUTO_DOWNLOAD=false
ECHOBOT_TTS_KOKORO_MODEL_DIR=
ECHOBOT_TTS_KOKORO_PROVIDER=cpu
ECHOBOT_TTS_KOKORO_NUM_THREADS=2
ECHOBOT_TTS_KOKORO_DEFAULT_VOICE=zf_001
ECHOBOT_TTS_KOKORO_DOWNLOAD_TIMEOUT_SECONDS=600
ECHOBOT_TTS_KOKORO_URL=
ECHOBOT_TTS_KOKORO_ALLOW_PRIVATE_DOWNLOAD=false
ECHOBOT_TTS_KOKORO_LENGTH_SCALE=1.0
ECHOBOT_TTS_KOKORO_LANG=

# TTS provider: OpenAI-compatible /audio/speech
ECHOBOT_TTS_OPENAI_API_KEY=EMPTY
ECHOBOT_TTS_OPENAI_MODEL=
ECHOBOT_TTS_OPENAI_BASE_URL=https://api.openai.com/v1
ECHOBOT_TTS_OPENAI_TIMEOUT=60
ECHOBOT_TTS_OPENAI_DEFAULT_VOICE=alloy
ECHOBOT_TTS_OPENAI_RESPONSE_FORMAT=wav
ECHOBOT_TTS_OPENAI_VOICES=
ECHOBOT_TTS_OPENAI_INSTRUCTIONS=
ECHOBOT_TTS_OPENAI_EXTRA_BODY=

# Web ASR
ECHOBOT_ASR_PROVIDER=sherpa-sense-voice
ECHOBOT_ASR_SAMPLE_RATE=16000
ECHOBOT_ASR_SHERPA_AUTO_DOWNLOAD=true
ECHOBOT_ASR_SHERPA_MODEL_DIR=
ECHOBOT_ASR_SHERPA_EXECUTION_PROVIDER=cpu
ECHOBOT_ASR_SHERPA_NUM_THREADS=2
ECHOBOT_ASR_SHERPA_LANGUAGE=auto
ECHOBOT_ASR_SHERPA_USE_ITN=false
ECHOBOT_ASR_SHERPA_DOWNLOAD_TIMEOUT_SECONDS=600
ECHOBOT_ASR_SHERPA_MODEL_URL=
ECHOBOT_ASR_SHERPA_ALLOW_PRIVATE_DOWNLOAD=false

# ASR provider: OpenAI-compatible /audio/transcriptions
ECHOBOT_ASR_OPENAI_API_KEY=EMPTY
ECHOBOT_ASR_OPENAI_MODEL=
ECHOBOT_ASR_OPENAI_BASE_URL=https://api.openai.com/v1
ECHOBOT_ASR_OPENAI_TIMEOUT=60
ECHOBOT_ASR_OPENAI_LANGUAGE=
ECHOBOT_ASR_OPENAI_PROMPT=
ECHOBOT_ASR_OPENAI_TEMPERATURE=

# Web VAD
ECHOBOT_VAD_PROVIDER=silero
ECHOBOT_VAD_SILERO_AUTO_DOWNLOAD=true
ECHOBOT_VAD_SILERO_MODEL_DIR=
ECHOBOT_VAD_SILERO_EXECUTION_PROVIDER=cpu
ECHOBOT_VAD_SILERO_DOWNLOAD_TIMEOUT_SECONDS=600
ECHOBOT_VAD_SILERO_MODEL_URL=
ECHOBOT_VAD_SILERO_ALLOW_PRIVATE_DOWNLOAD=false
ECHOBOT_VAD_SILERO_THRESHOLD=0.5
ECHOBOT_VAD_SILERO_MIN_SILENCE_SECONDS=0.4
ECHOBOT_VAD_SILERO_MIN_SPEECH_SECONDS=0.2
ECHOBOT_VAD_SILERO_MAX_SPEECH_SECONDS=30
ECHOBOT_VAD_SILERO_WINDOW_SIZE=512

# Logging
REME_LOG_LEVEL=WARNING
AGENTSCOPE_LOG_LEVEL=WARNING
