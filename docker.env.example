# Copy this file to docker.env.local.
# Do not commit docker.env.local.

# Compose binds ingress to 127.0.0.1:8080 by default. ECHOBOT_HOST_PORT is a
# Compose interpolation value, so set it in the invoking shell or project .env,
# not in this container env_file.

# OpenAI-compatible provider. Keep secrets outside the image.
# For GB10 / LiteLLM / Ollama / vLLM, point this at your external provider.
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=
LLM_API_KEY=

# Optional external speech providers. Use these when ASR/TTS is served by
# a GPU/provider stack instead of the app container.
ECHOBOT_TTS_PROVIDER=edge
ECHOBOT_TTS_OPENAI_BASE_URL=https://api.openai.com/v1
ECHOBOT_TTS_OPENAI_MODEL=
ECHOBOT_TTS_OPENAI_API_KEY=EMPTY
ECHOBOT_ASR_PROVIDER=sherpa-sense-voice
ECHOBOT_ASR_OPENAI_BASE_URL=https://api.openai.com/v1
ECHOBOT_ASR_OPENAI_MODEL=
ECHOBOT_ASR_OPENAI_API_KEY=EMPTY

# Keep private model downloads disabled unless you intentionally use an
# approved internal artifact mirror.
ECHOBOT_TTS_KOKORO_ALLOW_PRIVATE_DOWNLOAD=false
ECHOBOT_ASR_SHERPA_ALLOW_PRIVATE_DOWNLOAD=false
ECHOBOT_VAD_SILERO_ALLOW_PRIVATE_DOWNLOAD=false

# EchoBot safety defaults.
ECHOBOT_DEPLOYMENT_PROFILE=local
ECHOBOT_SHELL_SAFETY_MODE=workspace-write
ECHOBOT_TRUSTED_USER_HEADER_ENABLED=false
ECHOBOT_TRUSTED_USER_REQUIRED=false
ECHOBOT_TRUSTED_USER_ASSERTION_REQUIRED=false
ECHOBOT_ADMIN_ALLOWLIST=
ECHOBOT_ADMIN_REQUIRED=false
ECHOBOT_OPERATOR_ALLOWLIST=

# Runtime capacity and Stage delivery. The packaged default is one worker with
# the bounded in-memory broker. Set redis plus a reachable URL for multi-worker.
ECHOBOT_USER_RUNTIME_MAX_ENTRIES=16
ECHOBOT_USER_RUNTIME_IDLE_TTL_SECONDS=1800
ECHOBOT_STAGE_BROKER=memory
ECHOBOT_STAGE_WORKER_COUNT=1
ECHOBOT_STAGE_REDIS_URL=
ECHOBOT_STAGE_HISTORY_LIMIT=100
ECHOBOT_STAGE_QUEUE_LIMIT=100
ECHOBOT_STAGE_MAX_CHANNELS=256
ECHOBOT_STAGE_HEARTBEAT_SECONDS=15
ECHOBOT_STAGE_REDIS_TTL_SECONDS=86400
ECHOBOT_STAGE_REDIS_READ_BLOCK_MS=1000
ECHOBOT_STAGE_REDIS_STREAM_KEY_PREFIX=echobot:stage-events

# Optional bridge/channel secrets belong here when needed.
ECHOBOT_OPENWEBUI_BRIDGE_TOKEN=
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
